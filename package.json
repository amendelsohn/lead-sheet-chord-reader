{
  "name": "lead-sheet-chord-reader",
  "version": "1.0.0",
  "description": "Clean chord reader for Ultimate Guitar and E-Chords",
  "author": "Andrew Mendelsohn <andrew@mendelsohnlabs.com> (https://ko-fi.com/andrewmendelsohn)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && node build.mjs",
    "build:firefox": "tsc --noEmit && node build.mjs --target=firefox",
    "build:all": "npm run build && npm run build:firefox",
    "dev": "node build.mjs --watch",
    "dev:firefox": "node build.mjs --watch --target=firefox",
    "android:run": "web-ext run -t firefox-android --firefox-apk=org.mozilla.fenix --adb-device=$(adb devices | awk 'NR==2{print $1}') --source-dir=./dist-firefox",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "clean": "rm -rf dist dist-firefox"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "web-ext": "^8.0.0"
  }
}
